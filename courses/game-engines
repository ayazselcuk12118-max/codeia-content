          "items": [
            "extends Node2D — bu script hangi node tipini genişletiyor",
            "func _ready(): — sahne yüklenince bir kez çalışır",
            "func _process(delta): — her frame çalışır",
            "print('Merhaba') — konsola mesaj yaz",
            "Python gibi okunur — girintileme zorunlu"
          ]
        }
