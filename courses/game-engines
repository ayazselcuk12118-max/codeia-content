        {
          "type": "table",
          "title": "Unity Editör Panelleri",
          "headers": ["Panel", "Kısayol", "Ne İşe Yarar?"],
          "rows": [
            ["Scene", "Ctrl+1", "Oyun dünyasını görsel olarak düzenle"],
            ["Game", "Ctrl+2", "Oyunun çalışma önizlemesi"],
            ["Hierarchy", "Ctrl+4", "Sahnedeki tüm nesnelerin listesi"],
            ["Project", "Ctrl+5", "Tüm dosya ve asset'lerin listesi"],
            ["Inspector", "Ctrl+3", "Seçili nesnenin özellikleri"],
            ["Console", "Ctrl+Shift+C", "Hata mesajları ve debug logları"]
